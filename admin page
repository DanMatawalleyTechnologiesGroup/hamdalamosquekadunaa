import React, { useState, useEffect } from 'react';
import { base44 } from '@/api/base44Client';
import { Plus, Headphones, Video, BookOpen, Trash2, Star, Edit2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { useToast } from '@/components/ui/use-toast';

const CATEGORIES = ['Tafsiri', 'Hadisi', 'Fiqhu', 'Sira', 'Tauhidi', "Wa'azi", "Fannut Ta'amul", 'Iziyya', 'Sauran'];
const LANGUAGES = ['Hausa', 'Larabci', 'Turanci'];

function UploadField({ label, value, onChange, accept }) {
  const [uploading, setUploading] = useState(false);

  async function handleUpload(e) {
    const file = e.target.files[0];
    if (!file) return;
    setUploading(true);
    const { file_url } = await base44.integrations.Core.UploadFile({ file });
    onChange(file_url);
    setUploading(false);
  }

  return (
    <div>
      <label className="text-sm font-medium text-foreground mb-1 block">{label}</label>
      {value && <p className="text-xs text-primary truncate mb-1">✓ An ɗora fayil</p>}
      <div className="flex gap-2">
        <Input value={value || ''} onChange={e => onChange(e.target.value)} placeholder="URL ko ɗora fayil" className="flex-1" />
        <label className="cursor-pointer">
          <input type="file" accept={accept} className="hidden" onChange={handleUpload} />
          <span className="inline-flex items-center px-3 py-2 bg-primary/10 text-primary rounded-lg text-xs font-medium hover:bg-primary/20 transition-colors">
            {uploading ? '...' : 'Ɗora'}
          </span>
        </label>
      </div>
    </div>
  );
}

function AudioForm({ onSave, initial, onCancel }) {
  const [form, setForm] = useState(initial || { title: '', speaker: '', description: '', audio_url: '', cover_image: '', duration: '', category: '', language: 'Hausa', is_featured: false });
  const [saving, setSaving] = useState(false);

  async function handleSubmit(e) {
    e.preventDefault();
    if (!form.title || !form.audio_url) return;
    setSaving(true);
    await onSave(form);
    setSaving(false);
  }

  return (
    <form onSubmit={handleSubmit} className="space-y-3">
      <Input placeholder="Sunan Wa'azi *" value={form.title} onChange={e => setForm({ ...form, title: e.target.value })} required />
      <Input placeholder="Sunan Malami *" value={form.speaker} onChange={e => setForm({ ...form, speaker: e.target.value })} />
      <Input placeholder="Bayani" value={form.description} onChange={e => setForm({ ...form, description: e.target.value })} />
      <UploadField label="Fayilin Audio *" value={form.audio_url} onChange={v => setForm({ ...form, audio_url: v })} accept="audio/*" />
      <UploadField label="Hoton Murfin" value={form.cover_image} onChange={v => setForm({ ...form, cover_image: v })} accept="image/*" />
      <div className="grid grid-cols-2 gap-3">
        <Input placeholder="Tsawon lokaci (45:30)" value={form.duration} onChange={e => setForm({ ...form, duration: e.target.value })} />
        <Select value={form.category} onValueChange={v => setForm({ ...form, category: v })}>
          <SelectTrigger><SelectValue placeholder="Nau'i" /></SelectTrigger>
          <SelectContent>
            {CATEGORIES.map(c => <SelectItem key={c} value={c}>{c}</SelectItem>)}
          </SelectContent>
        </Select>
      </div>
      <div className="flex items-center gap-3">
        <Select value={form.language} onValueChange={v => setForm({ ...form, language: v })}>
          <SelectTrigger className="w-32"><SelectValue /></SelectTrigger>
          <SelectContent>
            {LANGUAGES.map(l => <SelectItem key={l} value={l}>{l}</SelectItem>)}
          </SelectContent>
        </Select>
        <label className="flex items-center gap-2 text-sm text-foreground cursor-pointer">
          <input type="checkbox" checked={form.is_featured} onChange={e => setForm({ ...form, is_featured: e.target.checked })} className="rounded" />
          Shahararriyya
        </label>
      </div>
      <div className="flex gap-2 pt-2">
        <Button type="submit" className="flex-1" disabled={saving}>
          {saving ? 'Ana ajiyewa...' : (initial ? 'Sabunta' : "Ɗora Wa'azi")}
        </Button>
        {onCancel && <Button type="button" variant="outline" onClick={onCancel}>Soke</Button>}
      </div>
    </form>
  );
}

